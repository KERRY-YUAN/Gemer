{
  "manifest_version": 3,
  "name": "Gemer Web Bridge",
  "version": "0.4.1",
  "description": "连接浏览器端 AI 与您本地电脑的物理控制桥梁。",
  "permissions": ["activeTab", "nativeMessaging"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://aistudio.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://aistudio.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}